# ==========================================================================
# Cấu hình Aegis AI Employee System
# ==========================================================================

# --- Phương thức AI: Chọn một trong hai ---

# Phương án 1: Chạy Local qua Ollama (Khuyến nghị nhờ có GPU RTX Quadro 6000)
USE_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.6:latest

# Phương án 2: Sử dụng DeepSeek Cloud API
# USE_OLLAMA=false
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# --- Cấu hình Subtitle Engine (GPU CUDA) ---
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# --- Cấu hình Playwright Browser ---
# true = chạy ẩn nền, false = hiện trình duyệt trực tiếp để quan sát
PLAYWRIGHT_HEADLESS=true
BROWSER_TIMEOUT=30000

# --- Cấu hình Telegram Bot ---
# Điền token Telegram Bot của bạn nhận được từ @BotFather tại đây để kích hoạt tính năng
TELEGRAM_BOT_TOKEN=8950465196:AAGvPytkC5FOLUtHnC4AGC7R-9G2BjYJSXA
